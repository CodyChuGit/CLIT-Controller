{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "agentflow-backend",
      "runtimeExecutable": ".venv/bin/python",
      "runtimeArgs": ["-m", "agentflow"],
      "port": 8787,
      "autoPort": false
    },
    {
      "name": "agentflow-frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev"],
      "port": 5180,
      "autoPort": false
    }
  ]
}
