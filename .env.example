# CLIT Controller IDE — environment variables
#
# This is a LOCAL-FIRST developer tool. Almost all runtime configuration lives in
# JSON files (~/.agentflow/config.json globally and <workspace>/.agentflow/ per
# project), NOT in environment variables. The few real env knobs are below.
#
# Copy to `.env` only if you need to override a default; the app reads these from
# the process environment, so exporting them in your shell works too.

# Port the backend (and, in single-port mode, the built frontend) binds on.
# Bound to 127.0.0.1 only — see docs/SECURITY.md. Default: 8787.
AGENTFLOW_PORT=8787

# Shell used for live PTY terminal sessions. Defaults to your login $SHELL, then
# /bin/bash. Override only to force a specific shell for agent terminals.
# SHELL=/bin/zsh

# NOTE: provider CLIs (claude, codex, agy) authenticate through their own
# mechanisms (their own config/keychain). Do NOT put provider API keys here —
# this app never reads them and never should. See docs/SECURITY.md.
